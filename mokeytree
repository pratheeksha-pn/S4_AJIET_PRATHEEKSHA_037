public class MonkeyTree{
    public static int monkeysLeft(int n, int m, int p, int k, int j) {
        int MB=m/k;
        int MP=p/j;
        int totalEaten = MB + MP;
        if (m % k > 0 && p % j > 0) {
            totalEaten++;
        }
        return Math.max(0, n - totalEaten);
    }
    public static void main(String[] args) {
        int n = 20;  
        int m = 12; 
        int p = 12;  
        int k = 2;   
        int j = 3;   
        System.out.println("Monkeys left on the tree: " + monkeysLeft(n, m, p, k, j));
    }
}
